spring.application.name=Chok

spring.datasource.url=jdbc:mysql://localhost:3306/chok?useSSL=false&serverTimezone=Asia/Seoul&characterEncoding=UTF-8&allowPublicKeyRetrieval=true
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver
spring.datasource.username=root
spring.datasource.password=CHANGE_ME

spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=false
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.MySQLDialect

spring.sql.init.mode=never
spring.sql.init.schema-locations=classpath:db/schema.sql

# chok.anthropic.* - Claude API for news sentiment analysis
chok.anthropic.api-key=CHANGE_ME
chok.anthropic.model=claude-sonnet-4-6
chok.anthropic.base-url=https://api.anthropic.com/v1/messages

# chok.analysis.* - final score weights (technical 65% + sentiment 35%)
chok.analysis.weight-technical=0.65
chok.analysis.weight-sentiment=0.35
chok.analysis.news-per-stock=5
chok.analysis.news-lookback-days=3
chok.analysis.parallelism=5

# chok.python-collector.* - python-collector 폴더 위치 (상대경로 기본값, 프로젝트 루트 기준)
# 이 값 하나만 있으면 파이썬 실행파일/스크립트/모델파일 경로는 자동으로 계산됨 (OS도 자동 감지)
# 다른 위치에 두고 싶으면 절대경로로 바꿔도 됨: chok.python-collector.base-dir=C:\\path\\to\\python-collector
chok.python-collector.base-dir=python-collector

# chok.collector.* - price collection settings
chok.collector.timeout-seconds=120

# chok.scheduler.* - automatic daily collection + analysis
chok.scheduler.enabled=true
chok.scheduler.cron=0 30 18 * * MON-FRI

# chok.model.* - rise-probability logistic regression model
chok.model.retrain-enabled=false
chok.model.retrain-cron=0 0 20 * * SUN
chok.model.timeout-seconds=300
chok.model.min-samples=500
