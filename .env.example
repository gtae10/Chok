# =========================================================
# 촉(Chok) 환경변수 설정 예시
# 이 파일을 복사해서 .env 파일로 만들고 실제 값을 채워주세요.
# .env 파일은 절대 깃에 올리지 마세요.
# =========================================================

# Claude API (https://console.anthropic.com 에서 발급)
ANTHROPIC_API_KEY=

# MySQL DB 접속 정보
DB_HOST=localhost
DB_PORT=3306
DB_NAME=chok
DB_USER=root
DB_PASSWORD=

# Python 수집기 설정
PYTHON_EXECUTABLE=python
COLLECTOR_WORKING_DIR=./python-collector
